# cxr-agent/cxr_agents/cxr_orchestrator/orchestrator_agent.py
"""
CXR Orchestrator Agent
======================
Defines the OpenAI Agents SDK agent, its tool functions, and the pipeline
runner for the chest X-ray analysis workflow.

Uses Claude claude-opus-4-6 via the LiteLLM extension for the Agents SDK.
Data classes are defined in models/pipeline.py — none are declared here.
Tool implementations live in tools/*/

The structured findings summary is an INTERMEDIATE artifact: the orchestrator
distils it from the reasoning output and records it via record_findings_summary
(no separate model call — the orchestrator emits it as tool arguments), then
uses its salient findings to guide localization.

Usage:
    python orchestrator_agent.py --image path/to/cxr.jpg [--query "..."]
"""

from __future__ import annotations

import argparse
import asyncio
import base64
import contextlib
import json
import os
import sys
import time
from pathlib import Path

from agents import Agent, Runner, function_tool
from agents.extensions.models.litellm_model import LitellmModel

from models.pipeline import (
    CXRAnalysisResult,
    FindingsSummary,
    LocalizationResult,
    PipelineMeta,
    ReasoningReport,
    TriageResult,
)

ORCHESTRATOR_MODEL = "anthropic/claude-opus-4-6"
REASONING_MCP_URL = "https://mcp-nv-reason-cxr-3b.fastmcp.app/mcp"

# General anatomical regions NV-Locate-Anything is expected to recognise.
# nv-locate is open-vocabulary but grounds GENERAL structures far better than
# hyperspecific landmarks, so the orchestrator maps every finding's location to
# the closest term here. EDIT THIS LIST to match your nv-locate deployment's
# recognised labels (phrasing/granularity is yours to tune).
ANATOMY_LOCATIONS = [
    "right lung", "left lung",
    "right upper lung", "right middle lung", "right lower lung",
    "left upper lung", "left lower lung",
    "right hilum", "left hilum",
    "heart", "mediastinum", "aorta", "trachea",
    "right hemidiaphragm", "left hemidiaphragm",
    "bones",
]


