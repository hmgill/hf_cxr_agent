@function_tool
async def triage_image(image_path: str) -> str:
    """
    Triage a medical image before CXR analysis.

    Determines whether the image is a chest X-ray, its orientation
    (PA / AP / lateral), and any quality issues that may affect downstream
    analysis. Always call this tool first.

    Args:
        image_path: Absolute or relative path to the image file (JPEG or PNG).

    Returns:
        JSON-serialised TriageResult (validity, orientation, quality, notes).
    """
    import traceback
    try:
        sys.path.insert(0, str(Path(__file__).parent.parent.parent))
        from tools.triage import run_triage
        result = await run_triage(image_path)
        return result.model_dump_json()
    except Exception as e:
        err = traceback.format_exc()
        print(f"TRIAGE ERROR: {err}", file=sys.stderr, flush=True)
        return json.dumps({
            "valid": False,
            "is_chest_xray": False,
            "orientation": "unknown",
            "quality_grade": "non_diagnostic",
            "quality_issues": [],
            "triage_notes": f"Triage failed: {type(e).__name__}: {e}",
        })


@function_tool
async def reason_cxr(
    image_path: str,
    prompt: str = "Describe all findings in this chest X-ray in detail.",
    max_side: int = 1280,
) -> str:
    """
    Analyse a validated chest X-ray with NV-Reason-CXR-3B.

    Encodes the image and calls the FastMCP reasoning server *internally*. The
    base64 image is created and consumed inside this tool and never enters the
    agent's context — only the small findings text is returned to the model.

    Call this only after triage_image returns valid=True. If triage reported a
    suboptimal quality_grade, prefix the triage notes onto `prompt` so the
    model accounts for known quality issues.

    Args:
        image_path: Path to the validated CXR image (JPEG or PNG).
        prompt: Clinical question or instruction for the reasoning model.
        max_side: Max pixels on the longest side before encoding. Use 768 for
                  quick overviews, 1280 (default) for standard analysis, up to
                  1536 only when fine anatomical detail is critical.

    Returns:
        JSON object with "answer" and "thinking" on success, or "error" on
        failure. The "thinking" block is the model's chain-of-thought and is
        retained for downstream analysis only — do not surface it to users.
    """
    from tools.encode_image import encode_image_for_reasoning

    try:
        image_b64, image_id = encode_image_for_reasoning(image_path, max_side=max_side)
    except (FileNotFoundError, ValueError) as e:
        return json.dumps({"error": f"encode failed: {type(e).__name__}: {e}"})

    # Call the reasoning MCP server programmatically with the SDK's MCP client
    # class — NOT via the agent's mcp_servers=[...]. Registering it natively
    # would make the LLM emit the base64 image as a tool argument, blowing up
    # the context window. Calling it here keeps the payload out of the model.
    try:
        from agents.mcp import MCPServerStreamableHttp
    except ImportError:
        return json.dumps({
            "error": "agents.mcp unavailable; update openai-agents (and `pip install mcp`)"
        })

    try:
        async with MCPServerStreamableHttp(
            name="cxr-reasoning",
            params={"url": REASONING_MCP_URL},
            # NV-Reason cold starts + inference run well over a minute; the MCP
            # ClientSession default per-request response timeout is only 5s.
            client_session_timeout_seconds=300,
        ) as server:
            res = await server.call_tool(
                "reason_cxr",
                {"image_b64": image_b64, "image_id": image_id, "prompt": prompt},
            )
    except Exception as e:
        import traceback
        print(f"REASONING ERROR: {traceback.format_exc()}", file=sys.stderr, flush=True)
        return json.dumps({"error": f"reasoning call failed: {type(e).__name__}: {e}"})

    # call_tool returns an mcp CallToolResult; the server wraps its JSON
    # envelope in a text content block.
    content = getattr(res, "content", None)
    raw = getattr(content[0], "text", "") if content else ""
    try:
        data = json.loads(raw)
    except (json.JSONDecodeError, TypeError):
        # Server returned plain text rather than the documented envelope.
        return raw or json.dumps({"error": "empty response from reasoning server"})

    if not data.get("success", False):
        return json.dumps({"error": data.get("error", "reasoning failed")})

    # Return the answer plus the chain-of-thought. The thinking block is kept
    # for downstream analysis (salience ranking) and persisted in the report,
    # but the orchestrator must not surface it to end users.
    answer = data.get("answer", "")
    thinking = data.get("thinking", "")
    return json.dumps({"answer": answer, "thinking": thinking})


# strict_mode=False: a free-form dict[str, str] param renders as
# `additionalProperties`, which the SDK's strict-schema mode rejects. Strict is
# an OpenAI structured-output concept, not enforced on the Anthropic/LiteLLM
# path, so disabling it here is harmless and keeps the typed dict signature.
@function_tool(strict_mode=False)
def record_findings_summary(
    is_normal: bool,
    salient_findings: dict[str, list[str]],
    summary: str,
    spoken_summary: str = "",
) -> str:
    """
    Record the structured findings summary you distilled from reason_cxr.

    Call this after reason_cxr succeeds and BEFORE localization. YOU generate
    the structured content yourself from the reasoning `answer` (using
    `thinking` only to judge salience) — this tool does NOT call any model; it
    only validates and stores what you provide. The `salient_findings` mapping
    you record here is exactly what you pass to `localize_findings` next.

    Args:
        is_normal: True if the study is unremarkable. Then salient_findings={}.
        salient_findings: Mapping of GENERAL anatomical location -> LIST of
                          findings at that region, e.g. {"right lower lung":
                          ["round opacity", "possible effusion"]}. Each key must
                          be a general region from the controlled list in the
                          system instructions. Put MULTIPLE findings for one
                          region in that region's list — never create a new key
                          for a second finding. Map hyperspecific landmarks to
                          the closest general region (e.g. "aortic arch" ->
                          "aorta"). Order locations most-to-least salient.
        summary: 1-3 sentence plain-language clinical summary.
        spoken_summary: 2-4 sentence narration written for the EAR (optional but
                        recommended). Plain language, no jargon dumps, no
                        coordinates or list syntax, derived from the vetted
                        findings only — NEVER from the thinking block. Fold in
                        any quality caveat from triage. This is the only text the
                        optional voice step will speak.

    Returns:
        JSON-serialised FindingsSummary (echoed back for your reference).
    """
    # Normalise location keys (strip + lowercase) and coerce each value to a
    # list of strings — tolerates a model that emits a bare string for a region.
    normalized = {
        (loc or "").strip().lower(): [
            str(x) for x in (findings if isinstance(findings, list) else [findings])
        ]
        for loc, findings in salient_findings.items()
    }
    s = FindingsSummary(
        is_normal=is_normal,
        salient_findings=normalized,
        summary=summary,
        spoken_summary=spoken_summary,
    )
    return s.model_dump_json()


@function_tool
async def localize_findings(image_path: str, targets_json: str) -> LocalizationResult:
    """
    Spatially ground salient findings onto the CXR with NV-Locate-Anything-3B.

    Call this only for ABNORMAL studies, using the `salient_findings` you
    recorded via record_findings_summary as the localization targets. Skip it
    for normal studies (nothing to ground).

    Args:
        image_path: Path to the CXR image.
        targets_json: JSON object of the salient findings to localize — the
                      `salient_findings` location->finding map from your
                      recorded summary, e.g. {"right lung": "fluid"}.

    Returns:
        LocalizationResult with per-finding bounding boxes.
    """
    from tools.locate import run_localization
    return await run_localization(image_path, targets_json)


