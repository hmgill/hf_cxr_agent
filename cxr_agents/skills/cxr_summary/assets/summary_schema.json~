{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FindingsSummary",
  "description": "Structured summary output for the CXR summary step.",
  "type": "object",
  "required": ["is_normal", "salient_findings", "summary"],
  "additionalProperties": false,
  "properties": {
    "is_normal": {
      "type": "boolean",
      "description": "True if the study shows no acute/clinically significant findings."
    },
    "salient_findings": {
      "type": "object",
      "description": "Mapping of anatomical location -> finding, e.g. {\"right lung\": \"fluid\"}. Insertion order is most-to-least salient. Empty if normal.",
      "additionalProperties": { "type": "string" }
    },
    "summary": {
      "type": "string",
      "description": "Concise plain-language clinical summary (1-3 sentences)."
    },
    "source_model": {
      "type": "string",
      "description": "Identifier of the model that produced this summary."
    }
  }
}
